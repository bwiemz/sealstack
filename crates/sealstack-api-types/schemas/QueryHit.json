{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.sealstack.dev/api-types/v0.3.0/QueryHit.json",
  "title": "QueryHit",
  "description": "One ranked hit in a [`QueryResponse`].",
  "type": "object",
  "required": [
    "id",
    "score"
  ],
  "properties": {
    "id": {
      "description": "Resource identifier.",
      "type": "string"
    },
    "title": {
      "description": "Display title or subject line.",
      "type": [
        "string",
        "null"
      ]
    },
    "snippet": {
      "description": "Snippet to render in UI.",
      "type": [
        "string",
        "null"
      ]
    },
    "score": {
      "description": "Combined hybrid score.",
      "type": "number",
      "format": "float"
    }
  }
}
