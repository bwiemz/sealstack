{
  "name": "@contextforge/sdk",
  "version": "0.1.0",
  "description": "ContextForge TypeScript SDK",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^9.16.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "engines": { "node": ">=20" }
}
