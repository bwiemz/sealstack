{
  "name": "sealstack-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SealStack administrative console.",
  "scripts": {
    "dev": "vite dev --port 7071",
    "build": "vite build",
    "preview": "vite preview --port 7071",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check ."
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.8.0",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.6",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.5",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1"
  }
}
