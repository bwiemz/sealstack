FROM rust:1.85-slim AS builder
WORKDIR /build
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*
COPY . .
RUN cargo build --release --bin cfg-gateway

FROM gcr.io/distroless/cc-debian12
COPY --from=builder /build/target/release/cfg-gateway /usr/local/bin/cfg-gateway
EXPOSE 7070
ENTRYPOINT ["/usr/local/bin/cfg-gateway"]
